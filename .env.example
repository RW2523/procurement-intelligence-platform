# =============================================================================
# PROCUREMENT INTELLIGENCE platform (Next.js) — environment template
# Copy to `.env.local` for local dev; set the same keys in Vercel for prod.
# All secret-consuming code is server-side (no browser Supabase client).
# =============================================================================

# ---- Supabase (shared project: coaszrosqlhifcwxurwu) ------------------------
NEXT_PUBLIC_SUPABASE_URL=https://coaszrosqlhifcwxurwu.supabase.co
# Server-only runtime DB key (this app uses the service role, not the anon key).
# From Supabase → Settings → API → service_role.
SUPABASE_SERVICE_ROLE_KEY=
# Server-only secret required by every RLS policy (defence in depth).
APP_DB_SECRET=

# ---- Site gate (TEMPORARY — replace with real Supabase Auth before launch) ---
# Enables site-wide HTTP Basic Auth. Any username; password must equal this.
# Leave BLANK locally. In production set a strong value until real auth lands.
SITE_PASSWORD=

# ---- Cron auth --------------------------------------------------------------
# Vercel Cron calls /api/cron with this bearer token. openssl rand -hex 32
CRON_SECRET=

# ---- LLM + embeddings (OpenRouter) — blank key ⇒ mock LLM + local-hash embeddings --
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
LLM_GENERATION_MODEL=openai/gpt-4o
LLM_DRAFT_MODEL=openai/gpt-4o-mini
LLM_SUMMARY_MODEL=openai/gpt-4o-mini
# RAG embeddings model. MUST be 1536-dim to match the vector(1536) column
# (openai/text-embedding-3-small = 1536). With OPENROUTER_API_KEY set, embeddings go
# through OpenRouter; blank ⇒ the free local hash embedder. Switching models/providers
# requires re-ingesting the knowledge library so all vectors come from one embedder.
EMBEDDING_MODEL=openai/text-embedding-3-small

# ---- Crawlers ---------------------------------------------------------------
# SAM.gov federal opportunities API key (optional; connector inactive without it).
SAM_GOV_API_KEY=
# Keep OFF on serverless (Vercel) — Playwright can't run there. MA falls back to page 1.
PLAYWRIGHT_ENABLED=false
CRAWL_USER_AGENT=AJACE-ProcurementBot/1.0 (+contact info@ajace.com)
